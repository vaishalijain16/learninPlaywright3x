<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">
<suite name="Salesforce Login Test Suite" verbose="1">
    <parameter name="url" value="https://login.salesforce.com/?locale=in"/>
    <parameter name="validUsername" value="your-valid-email@example.com"/>
    <parameter name="validPassword" value="your-valid-password"/>
    <parameter name="invalidUsername" value="invalid@example.com"/>
    <parameter name="invalidPassword" value="wrongpassword"/>
    <test name="Login Tests">
        <classes>
            <class name="com.salesforce.tests.ValidLoginTest"/>
            <class name="com.salesforce.tests.InvalidLoginTest"/>
        </classes>
    </test>
</suite>
